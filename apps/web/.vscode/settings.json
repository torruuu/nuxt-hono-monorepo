{
  "editor.tabSize": 2,
  "files.eol": "\n",
  "files.associations": {
    "*.css": "tailwindcss"
  },
  "stylelint.enable": true,
  "eslint.enable": true,
  "stylelint.validate": ["css", "vue", "tailwindcss"],
  "eslint.validate": ["javascript", "typescript", "vue"],
  "prettier.documentSelectors": ["**/*.json"],
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "always",
    "source.fixAll.prettier": "always"
  }
}
